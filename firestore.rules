rules_version = '2';

// MVP Rules: Open for testing. In production, require authentication.
service cloud.firestore {
  match /databases/{database}/documents {
    match /reports/{document=**} {
      allow read, write: if true;
    }
    match /report_chunks/{document=**} {
      allow read, write: if true;
    }
    match /market_gaps/{document=**} {
      allow read, write: if true;
    }
    match /competitors/{document=**} {
      allow read, write: if true;
    }
  }
}
